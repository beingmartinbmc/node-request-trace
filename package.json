{
  "name": "node-request-trace",
  "version": "2.0.0",
  "description": "Request tracing and performance visualization library for Node.js",
  "main": "index.js",
  "bin": {
    "node-request-trace": "./bin/cli.js"
  },
  "files": [
    "index.js",
    "lib/",
    "bin/"
  ],
  "scripts": {
    "test": "node test/run.js",
    "test:coverage": "c8 --100 --include='lib/**' --include='index.js' node test/run.js",
    "example": "node example/express-app.js"
  },
  "keywords": [
    "tracing",
    "performance",
    "middleware",
    "express",
    "fastify",
    "koa",
    "debugging",
    "monitoring"
  ],
  "author": "beingmartinbmc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beingmartinbmc/node-request-trace.git"
  },
  "homepage": "https://github.com/beingmartinbmc/node-request-trace#readme",
  "bugs": {
    "url": "https://github.com/beingmartinbmc/node-request-trace/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "koa": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "koa": {
      "optional": true
    }
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
